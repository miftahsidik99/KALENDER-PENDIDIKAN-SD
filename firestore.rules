rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users/{userId}/schoolSettings/{year}
    // Fields:
    //   - uid: string (required) - must match userId
    //   - startYear: number (required)
    //   - schoolDays: number (required, 5 or 6)
    //   - identity: map (required)
    //   - holidays: list (required)
    //   - updatedAt: string (required)
    //
    // Collection: users/{userId}/classSettings/{year_grade}
    // Fields:
    //   - uid: string (required) - must match userId
    //   - startYear: number (required)
    //   - grade: number (required)
    //   - schoolDays: number (required, 5 or 6)
    //   - identity: map (required)
    //   - holidays: list (required)
    //   - schedule: list (required)
    //   - curriculum: list (required)
    //   - updatedAt: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // Domain Validators
    function isValidSchoolSettings() {
      let data = request.resource.data;
      return data.keys().hasAll(['uid', 'startYear', 'schoolDays', 'identity', 'holidays', 'updatedAt']) &&
             data.uid is string &&
             data.startYear is number &&
             data.schoolDays is number && (data.schoolDays == 5 || data.schoolDays == 6) &&
             data.identity is map &&
             data.holidays is list &&
             data.updatedAt is string;
    }

    function isValidClassSettings() {
      let data = request.resource.data;
      return data.keys().hasAll(['uid', 'startYear', 'grade', 'schoolDays', 'identity', 'holidays', 'schedule', 'curriculum', 'updatedAt']) &&
             data.uid is string &&
             data.startYear is number &&
             data.grade is number &&
             data.schoolDays is number && (data.schoolDays == 5 || data.schoolDays == 6) &&
             data.identity is map &&
             data.holidays is list &&
             data.schedule is list &&
             data.curriculum is list &&
             data.updatedAt is string;
    }

    match /users/{userId}/schoolSettings/{year} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSchoolSettings() && uidUnchanged();
      allow update: if isOwner(userId) && isValidSchoolSettings() && uidNotModified();
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/classSettings/{year_grade} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidClassSettings() && uidUnchanged();
      allow update: if isOwner(userId) && isValidClassSettings() && uidNotModified();
      allow delete: if isOwner(userId);
    }
  }
}
